<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="16dp">

        <TextView
            android:id="@+id/tvTitle"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="NFC Safe Tools"
            android:textSize="24sp"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/tvSafety"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:text="Gunakan hanya untuk tag milik sendiri. Aplikasi ini hanya menangani NDEF dan demo HCE custom, bukan cloning kartu akses."
            android:textSize="14sp" />

        <TextView
            android:id="@+id/tvStatus"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            android:text="Status: siap. Tempelkan tag NFC ke ponsel."
            android:textStyle="bold" />

        <TextView
            android:id="@+id/tvTagInfo"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            android:text="Info tag akan muncul di sini." />

        <EditText
            android:id="@+id/etName"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="16dp"
            android:hint="Nama payload tersimpan (mis. Tag Gudang Sendiri)" />

        <EditText
            android:id="@+id/etPayload"
            android:layout_width="match_parent"
            android:layout_height="160dp"
            android:layout_marginTop="12dp"
            android:gravity="top|start"
            android:hint="Teks NDEF akan tampil di sini atau isi teks baru untuk ditulis"
            android:inputType="textMultiLine"
            android:minLines="6" />

        <Button
            android:id="@+id/btnSavePayload"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            android:text="Simpan Payload Terakhir" />

        <Button
            android:id="@+id/btnLoadPayload"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:text="Muat Payload Tersimpan" />

        <Button
            android:id="@+id/btnWriteText"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:text="Tulis Teks ke Tag" />

        <Button
            android:id="@+id/btnWriteSaved"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:text="Tulis Payload Tersimpan ke Tag" />

        <Button
            android:id="@+id/btnPrepareHce"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:text="Siapkan Payload Demo HCE" />

        <TextView
            android:id="@+id/tvHceInfo"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            android:text="HCE demo menggunakan AID custom dan payload milik sendiri. Aktifkan NFC dan pastikan perangkat mendukung HCE."
            android:textSize="13sp" />

    </LinearLayout>
</ScrollView>
